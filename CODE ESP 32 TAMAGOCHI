#include <Wire.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>

// Configuración OLED
#define SCREEN_WIDTH 128
#define SCREEN_HEIGHT 64
// Usa pines 21 y 22 para el ESP32
Adafruit_SSD1306 display(SCREEN_WIDTH, SCREEN_HEIGHT, &Wire, -1);

// Pines Sensores
const int PIN_TRIG = 26;
const int PIN_ECHO = 25;
const int PIN_BUZZER = 27;

void setup() {
  Serial.begin(115200);
  
  // Configuración de pines
  pinMode(PIN_TRIG, OUTPUT);
  pinMode(PIN_ECHO, INPUT);
  pinMode(PIN_BUZZER, OUTPUT);

  // Inicializar Pantalla
  if(!display.begin(SSD1306_SWITCHCAPVCC, 0x3C)) { 
    Serial.println(F("OLED no encontrado"));
    for(;;);
  }
  display.clearDisplay();
  display.setTextColor(WHITE);
}

void loop() {
  // Medir distancia
  digitalWrite(PIN_TRIG, LOW);
  delayMicroseconds(2);
  digitalWrite(PIN_TRIG, HIGH);
  delayMicroseconds(10);
  digitalWrite(PIN_TRIG, LOW);
  
  long duration = pulseIn(PIN_ECHO, HIGH);
  int distance = duration * 0.034 / 2;

  display.clearDisplay();
  display.setCursor(0, 50);

  if (distance > 25) {
    // CARITA FELIZ
    display.setTextSize(1);
    display.setCursor(35, 10); display.print("^  ^");
    display.setCursor(35, 30); display.print("\\____/");
    display.setCursor(25, 55); display.print("ESTOY FELIZ");
    noTone(PIN_BUZZER);
  } 
  else if (distance >= 15 && distance <= 25) {
    // CARITA NORMAL
    display.setTextSize(1);
    display.setCursor(35, 10); display.print("O  O");
    display.setCursor(35, 30); display.print("------");
    display.setCursor(30, 55); display.print("TODO BIEN");
    tone(PIN_BUZZER, 440); // Tono suave
  } 
  else if (distance >= 8 && distance < 15) {
    // CARITA ASUSTADA
    display.setTextSize(1);
    display.setCursor(35, 10); display.print("o  o");
    display.setCursor(45, 30); display.print("O");
    display.setCursor(25, 55); display.print("TE ACERCAS!");
    tone(PIN_BUZZER, 880); // Tono más fuerte
  } 
  else {
    // CARITA PANICO (7cm o menos)
    display.setTextSize(1);
    display.setCursor(35, 10); display.print(">  <");
    display.setCursor(35, 30); display.print("vvvvvv");
    display.setCursor(30, 55); display.print("CUIDAOOO!");
    tone(PIN_BUZZER, 1500); // Tono de pánico
  }

  display.display();
  delay(100);
}
